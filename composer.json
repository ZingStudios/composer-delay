{
    "name": "zingstudios/composer-delay",
    "authors": [
        {
            "name": "Ben Mason",
            "email": "ben@zingstudios.com"
        }
    ],
    "homepage": "https://github.com/ZingStudios/composer-delay",
    "support": {
        "issues": "https://github.com/ZingStudios/composer-delay/issues"
    },
    "description": "Composer plugin that blocks installation of packages newer than a configurable threshold.",
    "type": "composer-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Zingstudios\\ComposerDelay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zingstudios\\ComposerDelay\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "Zingstudios\\ComposerDelay\\Plugin"
    },
    "config": {
        "sort-packages": true
    }
}
